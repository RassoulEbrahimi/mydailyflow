# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── Demo-only fake auth ───────────────────────────────────────────────────────
# ⚠️  NOT SECURE. For development/demo use only.
#     These credentials are visible in the built JS bundle.
#     Remove before real production deployment.
VITE_FAKE_USER_1="Admin1"
VITE_FAKE_PASS_1="CHANGE_ME_1"

VITE_FAKE_USER_2="Admin2"
VITE_FAKE_PASS_2="CHANGE_ME_2"

VITE_FAKE_USER_3="Admin3"
VITE_FAKE_PASS_3="CHANGE_ME_3"

VITE_FAKE_USER_4="Admin4"
VITE_FAKE_PASS_4="CHANGE_ME_4"

VITE_FAKE_USER_5="Admin5"
VITE_FAKE_PASS_5="CHANGE_ME_5"

# ─── Voice Task Configuration ──────────────────────────────────────────────────
# VITE_API_BASE_URL: For production GitHub Pages, point this to your deployed backend URL.
# In local dev with Vite proxy, leave this blank.
VITE_API_BASE_URL=

# Backend Configuration (Express server.js)
PORT=8080
# Set CORS_ORIGIN to your GitHub Pages URL in production, e.g., https://username.github.io
# For local development or unrestricted access, keep it as *
CORS_ORIGIN=*

# Mistral AI configuration for transcription (Never expose to frontend!)
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-speech-to-text
